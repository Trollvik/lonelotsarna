---
const base = import.meta.env.BASE_URL;
---

<section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
  <!-- Hero background image -->
  <img
    src={`${base}/images/Lönelotsarna.jpg`}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
  />
  <!-- Overlay for text readability -->
  <div class="absolute inset-0 bg-black/30"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-medium uppercase tracking-wider mb-6">
      Experter på strukturella löneskillnader
    </h1>
    <p class="text-base sm:text-lg max-w-2xl mx-auto text-white/90">
      Ett nätverk av experter som sprider kunskap, bildar opinion och
      tillhandahåller det kostnadsfria verktyget Analys Lönelots.
    </p>
  </div>
</section>
