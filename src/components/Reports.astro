---
// Rapportdatan ligger i src/data/reports.json — redigera den filen,
// inte denna. Denna fil styr bara hur rapporterna visas.
import reports from '../data/reports.json';
const base = import.meta.env.BASE_URL;
---

<section id="rapporter" class="py-20 bg-brand-gray">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-medium text-brand-text uppercase tracking-wider mb-4 text-center">Rapporter</h2>
    <p class="text-brand-text/70 text-center max-w-3xl mx-auto mb-12">
      Som enda aktör följer Lönelotsarna utvecklingen av strukturella löneskillnader i Sverige.
      Genom att värdera kraven i arbetet för samtliga yrken på arbetsmarknaden har vi kunnat
      dela in dem i grupper av likvärdiga arbeten och jämföra lönerna.
    </p>

    <div class="space-y-4">
      {reports.map((report) => (
        <a
          href={`${base}${report.file}`}
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-white p-6 border-b border-gray-200 hover:shadow-md transition-shadow group"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-sm font-medium text-brand-red">
                  {report.year}
                </span>
                <h3 class="text-base font-medium text-brand-text group-hover:text-brand-red transition-colors">
                  {report.title}
                </h3>
              </div>
              <p class="text-brand-text/60 text-sm">{report.summary}</p>
            </div>
            <svg class="w-5 h-5 text-brand-text/30 group-hover:text-brand-red transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Lönelots-metoden -->
    <div class="mt-12 border-t border-brand-red pt-8 max-w-3xl mx-auto text-center">
      <h3 class="text-lg font-medium text-brand-text uppercase tracking-wider mb-3">Lönelots-metoden</h3>
      <p class="text-brand-text/70 text-sm mb-4">
        Lönelotsarna använder tre verktyg i sina studier som alla är kostnadsfria och lättillgängliga:
        Analys Lönelots, lönestrukturstatistiken och svensk standard för yrkesklassificering (SSYK).
      </p>
      <a
        href={`${base}/documents/Lönelots-metoden+241008.pdf`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-brand-red font-medium hover:text-brand-red-dark transition-colors"
      >
        Hämta Lönelots-metoden (PDF)
      </a>
    </div>
  </div>
</section>
