<script is:inline>
  (async function () {
    try {
      const res = await fetch('https://api.github.com/repos/Trollvik/lonelotsarna/releases');
      if (!res.ok) return;
      const releases = await res.json();
      const release = releases.find(r => r.assets && r.assets.length > 0);
      if (!release) return;

      const version = release.tag_name.replace(/^v/, '');
      const pc = release.assets.find(a => a.name.endsWith('.exe') && !a.name.includes('-EN'));
      const mac = release.assets.find(a => a.name.endsWith('.dmg') && !a.name.includes('-EN'));

      const versionEl = document.getElementById('version-text');
      if (versionEl) versionEl.textContent = 'Version ' + version + ', kostnadsfri för alla organisationer, stora som små.';
      if (pc) { const el = document.getElementById('download-pc'); if (el) el.href = pc.browser_download_url; }
      if (mac) { const el = document.getElementById('download-mac'); if (el) el.href = mac.browser_download_url; }
    } catch (e) { /* fallback to hardcoded links */ }
  })();
</script>

