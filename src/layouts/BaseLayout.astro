---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'sv' | 'en';
  ogImage?: string;
}

const base = import.meta.env.BASE_URL;
const siteUrl = 'https://trollvik.github.io';

const {
  title = 'Lönelotsarna – Jämställda löner genom kunskap och verktyg',
  description = 'Lönelotsarna är en ideell förening som verkar för jämställda löner genom kunskap, opinion och verktyget Analys Lönelots.',
  lang = 'sv',
  ogImage = `${base}/images/Lönelotsarna.jpg`,
} = Astro.props;

const isEn = lang === 'en';
const homeHref = isEn ? `${base}/en` : `${base}/`;
const currentPath = Astro.url.pathname;

// Build the alternate language URL
const altLang = isEn ? 'sv' : 'en';
const altPath = isEn
  ? currentPath.replace('/en/', '/').replace('/en', '/')
  : currentPath.replace(base, `${base}/en`);
const canonicalUrl = `${siteUrl}${currentPath}`;
const altUrl = `${siteUrl}${altPath}`;

const nav = isEn
  ? [
      { label: 'Lönelotsarna', href: `${base}/en` },
      { label: 'The Lonelots Tool', href: `${base}/en/analys-lonelots` },
    ]
  : [
      { label: 'Lönelotsarna', href: `${base}/` },
      { label: 'Analys Lönelots', href: `${base}/analys-lonelots` },
    ];
const langSwitch = isEn
  ? { label: 'Svenska', href: `${base}/` }
  : { label: 'English', href: `${base}/en` };
---

<!-- ============================================================
     LAYOUTFIL — styr navigation, footer och SEO-taggar.
     Redigera INTE denna fil om du inte vet vad du gör.
     Kontakta Emil för ändringar i navigation eller footer.
     ============================================================ -->
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang: connect Swedish and English versions -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content={isEn ? 'en_GB' : 'sv_SE'} />
    <meta property="og:site_name" content="Lönelotsarna" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <title>{title}</title>
  </head>
  <body class="bg-white antialiased">
    <!-- Navigation -->
    <nav class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-sm z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href={homeHref}>
            <img src={`${base}/images/Lonelotslogga.png`} alt="Lönelotsarna" class="h-8" />
          </a>
          <div class="hidden md:flex items-center space-x-8">
            {nav.map((item) => (
              <a href={item.href} class="text-brand-text/70 hover:text-brand-red transition-colors uppercase tracking-wider text-sm">{item.label}</a>
            ))}
            <a href={langSwitch.href} class="text-brand-text/40 hover:text-brand-text/70 transition-colors uppercase tracking-wider text-sm">{langSwitch.label}</a>
          </div>
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 rounded-md text-brand-text/70 hover:text-brand-red"
            aria-label={isEn ? 'Open menu' : 'Öppna meny'}
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
        <!-- Mobile menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          {nav.map((item) => (
            <a href={item.href} class="block py-2 text-brand-text/70 hover:text-brand-red uppercase tracking-wider text-sm">{item.label}</a>
          ))}
          <a href={langSwitch.href} class="block py-2 text-brand-text/40 hover:text-brand-text/70 uppercase tracking-wider text-sm">{langSwitch.label}</a>
        </div>
      </div>
    </nav>

    <main class="pt-16">
      <slot />
    </main>

    <footer class="bg-brand-dark text-white/50 py-8">
      <div class="max-w-6xl mx-auto px-4 text-center">
        <p>&copy; {new Date().getFullYear()} Lönelotsarna</p>
      </div>
    </footer>

    <!-- Mobile menu toggle -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
      menu?.querySelectorAll('a').forEach((link) =>
        link.addEventListener('click', () => menu?.classList.add('hidden'))
      );
    </script>
    <!-- Analytics (cookie-free) -->
    <script data-goatcounter="https://lonelotsarna.goatcounter.com/count"
      async src="//gc.zgo.at/count.js" is:inline></script>
  </body>
</html>
